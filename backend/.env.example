# ─── Required ─────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ─── Admin route (DEV/STAGING only) ───────────────────────────────────────────
# Protects DELETE /api/auth/admin/clear-db
ADMIN_SECRET=your_admin_secret_here

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Database (Vercel Postgres — production only) ──────────────────────────────
# POSTGRES_URL=your_postgres_connection_string
